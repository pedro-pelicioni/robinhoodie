{
  "name": "piedpiper",
  "version": "0.1.0",
  "private": true,
  "license": "MIT",
  "scripts": {
    "lint:fix": "prettier --write 'tests/**/*.ts' 'scripts/**/*.ts'",
    "lint": "prettier --check 'tests/**/*.ts' 'scripts/**/*.ts'",
    "test": "anchor test",
    "test:local": "anchor test --skip-local-validator",
    "build": "anchor build && yarn prepare:app",
    "prepare:app": "cp target/idl/prediction_market.json app/piedpiper-app/src/idl/prediction_market.json && echo \"IDL copied to app\"",
    "seed": "ts-node scripts/seed.ts",
    "settle": "ts-node scripts/settle.ts"
  },
  "dependencies": {
    "@coral-xyz/anchor": "^0.31.1",
    "@solana/spl-token": "^0.4.8",
    "@solana/web3.js": "^1.95.3"
  },
  "devDependencies": {
    "@solana/kit": "^6.9.0",
    "@types/bn.js": "^5.1.5",
    "@types/chai": "^4.3.16",
    "@types/mocha": "^10.0.7",
    "@types/node": "^20.14.10",
    "chai": "^4.5.0",
    "mocha": "^10.7.0",
    "prettier": "^3.3.2",
    "sas-lib": "^1.0.10",
    "ts-mocha": "^10.0.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.5.3"
  }
}
